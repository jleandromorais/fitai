spring.application.name=fitai-backend
server.port=8081

# Banco de dados
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/fitai}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD}
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# JWT — gere uma chave segura com: openssl rand -base64 64
jwt.secret=${JWT_SECRET}
jwt.expiration=${JWT_EXPIRATION:86400000}

# Google OAuth2 — obtenha em console.cloud.google.com
google.client-id=${GOOGLE_CLIENT_ID}
